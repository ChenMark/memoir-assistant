# 忆往昔回忆录助手 - 环境变量配置

# ============ OSS 云存储配置 ============
VITE_OSS_BUCKET=your-bucket-name
VITE_OSS_REGION=oss-cn-hangzhou
VITE_OSS_ENDPOINT=https://your-bucket.oss-cn-hangzhou.aliyuncs.com
VITE_BACKEND_URL=http://localhost:3001

# ============ 安全签名配置 ============
# sign mode: hmac (HMAC-SHA256, recommended) or md5
VITE_TELECOM_SIGN_MODE=hmac
VITE_TELECOM_APP_ID=your-telecom-app-id
VITE_TELECOM_APP_SECRET=your-telecom-app-secret

# ============ 隐私加密密钥 ============
VITE_ENCRYPTION_KEY=memoir-strong-encryption-key-change-this

# ============ 后端配置（服务器端）============
# 以下变量仅在后端 server/ 中使用，不要加 VITE_ 前缀
OSS_ACCESS_KEY_ID=your-aliyun-access-key-id
OSS_ACCESS_KEY_SECRET=your-aliyun-access-key-secret
OSS_BUCKET=your-bucket-name
OSS_REGION=oss-cn-hangzhou
BACKEND_PORT=3001
