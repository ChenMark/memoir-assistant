# 忆往昔后端服务 - 环境变量配置
# 复制此文件为 .env，填入真实值，不要提交 .env 到 git

# 阿里云 OSS 配置（必填）
OSS_ACCESS_KEY_ID=your-aliyun-access-key-id
OSS_ACCESS_KEY_SECRET=your-aliyun-access-key-secret
OSS_BUCKET=your-bucket-name
OSS_REGION=oss-cn-hangzhou

# 后端端口（可选，默认 3001）
BACKEND_PORT=3001

# 电信能力平台配置（可选，使用电信登录/身份证认证时需要）
TELECOM_APP_ID=your-telecom-app-id
TELECOM_APP_SECRET=your-telecom-app-secret
