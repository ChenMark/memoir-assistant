# ============================================================
# 忆往昔 回忆录助手 — 环境变量配置参考
# ============================================================
# 复制此文件为 .env 并填入实际值
# 开发环境：server/.env
# 生产环境：Vercel 后台 Environment Variables

# ============ 必需配置 ============

# JWT 密钥（用于 Token 签名与验证）
# 生成方式: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars

# ============ 数据库 ============

# SQLite (本地开发)
# 路径相对于 server/ 目录
DATABASE_URL=file:./dev.db

# PostgreSQL (生产环境)
# DATABASE_URL=postgresql://user:password@host:5432/memoir?schema=public

# ============ OSS 云存储 ============

# 阿里云 OSS 配置（可选，不配置则使用本地存储）
# OSS_ACCESS_KEY_ID=your-access-key-id
# OSS_ACCESS_KEY_SECRET=your-access-key-secret
# OSS_BUCKET=memoir-assistant
# OSS_REGION=oss-cn-hangzhou

# ============ 短信服务 ============

# 短信接口配置（可选，不配置则使用开发模式 123456）
# SM_SIGNATURE=memoir-app
# SMS_API_KEY=your-sms-api-key
# SMS_API_URL=https://sms-api.example.com/send

# ============ 第三方登录 ============

# 微信开放平台（可选）
# WECHAT_APP_ID=your-wechat-app-id
# WECHAT_APP_SECRET=your-wechat-app-secret
# WECHAT_REDIRECT_URI=https://your-domain.com/auth/wechat/callback

# QQ 互联（可选）
# QQ_APP_ID=your-qq-app-id
# QQ_APP_KEY=your-qq-app-key
# QQ_REDIRECT_URI=https://your-domain.com/auth/qq/callback

# ============ AI 服务 ============

# GitHub Models (免费)
# GITHUB_TOKEN=your-github-token

# HuggingFace (免费)
# HF_API_KEY=your-hf-api-key

# ============ 安全 ============

# CORS 允许的来源（逗号分隔）
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# 服务器端口
PORT=3000

# 前端后端 URL（生产环境需修改）
# VITE_API_BASE_URL=https://your-domain.com
