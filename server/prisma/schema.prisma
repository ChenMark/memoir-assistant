// Prisma Schema for memoir-assistant
// Database: SQLite (development), PostgreSQL (production)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============ User ============
model User {
  id             String   @id @default(cuid())
  email          String   @unique
  username       String   @unique
  passwordHash   String
  salt           String
  phone          String?  @unique
  phoneVerified  Boolean  @default(false)
  avatar         String?
  bio            String?
  wechatOpenId   String?
  wechatUnionId  String?
  wechatNickname String?
  qqOpenId       String?
  qqNickname     String?
  
  // Relations
  memoirs        Memoir[]
  drafts         Draft[]
  galleries      Gallery[]
  friends        Friend[]
  comments       PhotoComment[]
  hobbies        Hobby[]
  captures       CaptureSession[]
  conversations  AgentConversation[]
  notifications   Notification[]
  sessions        Session[]
  exports         ExportJob[]
  memoirComments  MemoirComment[]
  shareLinks      ShareLink[]
  bookmarks         Bookmark[]
  interviewSessions InterviewSession[]
  reminders         Reminder[]
  familyRelations   FamilyRelation[]
  emergencyContacts EmergencyContact[]
  emergencyAlerts   EmergencyAlert[]
  privacyCircles    PrivacyCircle[]
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("users")
}

// ============ Memoir ============
model Memoir {
  id          String   @id @default(cuid())
  userId      String
  title       String
  content     String
  tags        String   // JSON array string
  mood        String?
  location    String?
  date        String   // YYYY-MM-DD
  media       String   // JSON array string (OSS keys)
  isPublished Boolean  @default(false)
  
  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  galleries   Gallery[]
  comments    MemoirComment[]
  sharedLinks ShareLink[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@map("memoirs")
}

// ============ Draft ============
model Draft {
  id          String   @id @default(cuid())
  userId      String
  title       String
  content     String
  tags        String   // JSON array string
  mood        String?
  date        String?  // YYYY-MM-DD
  media       String   // JSON array string (OSS keys)
  
  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@map("drafts")
}

// ============ Gallery ============
model Gallery {
  id          String   @id @default(cuid())
  userId      String
  memoirId    String?
  ossKey      String
  caption     String   @default("")
  tags        String   // JSON array string
  date        String   // YYYY-MM-DD
  shareToken  String?  @unique  // 分享令牌，唯一且可撤销
  
  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  memoir      Memoir?  @relation(fields: [memoirId], references: [id], onDelete: SetNull)
  comments    PhotoComment[]

  createdAt   DateTime @default(now())

  @@index([userId])
  @@map("galleries")
}

// ============ PhotoComment ============
model PhotoComment {
  id        String   @id @default(cuid())
  galleryId String
  userId    String
  content   String
  
  // Relations
  gallery   Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([galleryId])
  @@map("photo_comments")
}

// ============ Friend ============
model Friend {
  id             String   @id @default(cuid())
  userId         String
  name           String
  avatar         String?
  addedAt        DateTime  @default(now())
  category       String   // 'family' | 'class_mate' | 'friend'
  relationship   String?  // 家族关系
  generation     Int?    // 辈分：+2,+3,+4=祖辈，+1=父辈，0=同辈，-1,-2,-3=子、孙辈
  parentId       String?  // 父节点ID，用于家族树
  spouseId       String?  // 配偶ID
  school         String?  // 学校
  classInfo      String?  // 班级信息
  graduationYear String?  // 毕业年份
  metAt          String?  // 认识地点
  metYear        String?  // 认识年份
  tags           String   // JSON array string，如工作单位、兴趣组等
  
  // Relations
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
  @@map("friends")
}

// ============ Hobby ============
model Hobby {
  id          String   @id @default(cuid())
  userId      String
  category    String   // 'music' | 'movie' | 'sport' | 'custom'
  title       String
  description String   @default("")
  rating      Int?    // 1-5星评分
  tags        String   // JSON array string
  year        String?  // 年份(金曲/电影)
  link        String?  // 外部链接
  imageKey    String?  // OSS图片key
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, category])
  @@map("hobbies")
}

// ============ CaptureSession ============
model CaptureSession {
  id           String   @id @default(cuid())
  userId       String
  type         String   // 'photo' | 'video'
  itemCount    Int      @default(0)  // 照片张数
  transcript   String   @default("")  // 语音转文字
  duration     Int?     // 视频时长(秒)
  ossKeys      String   // JSON: ["uploads/capture/xxx.jpg"]
  tags         String   @default("[]")  // JSON array
  date         String   // YYYY-MM-DD
  
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt    DateTime @default(now())

  @@index([userId, date])
  @@map("capture_sessions")
}

// ============ AgentConversation ============
model AgentConversation {
  id        String   @id @default(cuid())
  userId    String
  messages  String   // JSON: [{role, content, toolCalls?}]
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, updatedAt])
  @@map("agent_conversations")
}

// ============================================================
// 通知系统
// ============================================================
model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // 'comment' | 'share' | 'agent' | 'system' | 'reminder'
  title     String
  body      String
  link      String?  // 点击跳转路径
  meta      String   @default("{}")  // JSON 关联数据
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read, createdAt])
  @@map("notifications")
}

// ============================================================
// P0: 通知 / 导出 / 会话 / 评论 / 分享
// ============================================================
model Session {
  id           String   @id @default(cuid())
  userId       String
  deviceId     String
  tokenHash    String   @unique
  userAgent    String?
  ip           String?
  meta         String   @default("{}")
  lastActiveAt DateTime @default(now())
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@map("sessions")
}

model ExportJob {
  id        String   @id @default(cuid())
  userId    String
  type      String   // 'memoir' | 'all'
  status    String   @default("pending") // pending | processing | done | failed
  meta      String   @default("{}")
  filePath  String?
  fileSize  Int?
  error     String?
  expiresAt DateTime?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("export_jobs")
}

model MemoirComment {
  id        String   @id @default(cuid())
  memoirId  String
  userId    String
  content   String
  createdAt DateTime @default(now())

  memoir    Memoir   @relation(fields: [memoirId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([memoirId, createdAt])
  @@map("memoir_comments")
}

model ShareLink {
  id        String   @id @default(cuid())
  userId    String
  memoirId  String?
  token     String   @unique
  visits    Int      @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  memoir    Memoir?  @relation(fields: [memoirId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("share_links")
}

// ============================================================
// P1: 收藏 / 访谈存档 / 提醒
// ============================================================
model Bookmark {
  id         String   @id @default(cuid())
  userId     String
  targetType String   // 'memoir' | 'photo' | 'hobby' | 'friend'
  targetId   String
  note       String?
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, targetType, targetId])
  @@index([userId, createdAt])
  @@map("bookmarks")
}

model InterviewSession {
  id           String   @id @default(cuid())
  userId       String
  currentStage Int      @default(0)
  answers      String   @default("{}")
  summary      String?
  status       String   @default("in_progress")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("interview_sessions")
}

model Reminder {
  id         String   @id @default(cuid())
  userId     String
  type       String   // 'birthday' | 'anniversary' | 'memorial' | 'custom'
  title      String
  date       String   // YYYY-MM-DD
  recurring  Boolean  @default(true)
  note       String?
  remindDays String   @default("[0,1,7,30]") // 提前提醒天数
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@map("reminders")
}

// ============================================================
// P2: 家族关系 / 紧急联系人 / 隐私分组
// ============================================================
model FamilyRelation {
  id     String @id @default(cuid())
  userId String
  fromId String
  toId   String
  type   String // 'spouse' | 'parent' | 'child' | 'sibling'

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("family_relations")
}

model EmergencyContact {
  id        String   @id @default(cuid())
  userId    String
  name      String
  phone     String
  relation  String
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("emergency_contacts")
}

model EmergencyAlert {
  id            String   @id @default(cuid())
  userId        String
  message       String
  location      String?
  notifiedCount Int      @default(0)
  createdAt     DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("emergency_alerts")
}

model PrivacyCircle {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  color       String?
  memberIds   String   @default("[]") // JSON array of friend IDs
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("privacy_circles")
}
