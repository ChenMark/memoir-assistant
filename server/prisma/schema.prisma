// Prisma Schema for memoir-assistant
// Database: SQLite (development), PostgreSQL (production)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============ User ============
model User {
  id             String   @id @default(cuid())
  email          String   @unique
  username       String   @unique
  passwordHash   String
  salt           String
  phone          String?  @unique
  phoneVerified  Boolean  @default(false)
  avatar         String?
  bio            String?
  wechatOpenId   String?
  wechatUnionId  String?
  wechatNickname String?
  qqOpenId       String?
  qqNickname     String?
  
  // Relations
  memoirs        Memoir[]
  drafts         Draft[]
  galleries      Gallery[]
  friends        Friend[]
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("users")
}

// ============ Memoir ============
model Memoir {
  id          String   @id @default(cuid())
  userId      String
  title       String
  content     String
  tags        String   // JSON array string
  mood        String?
  location    String?
  date        String   // YYYY-MM-DD
  media       String   // JSON array string (OSS keys)
  isPublished Boolean  @default(false)
  
  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  galleries   Gallery[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@map("memoirs")
}

// ============ Draft ============
model Draft {
  id          String   @id @default(cuid())
  userId      String
  title       String
  content     String
  tags        String   // JSON array string
  mood        String?
  date        String?  // YYYY-MM-DD
  media       String   // JSON array string (OSS keys)
  
  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@map("drafts")
}

// ============ Gallery ============
model Gallery {
  id          String   @id @default(cuid())
  userId      String
  memoirId    String?
  ossKey      String
  caption     String   @default("")
  tags        String   // JSON array string
  date        String   // YYYY-MM-DD
  
  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  memoir      Memoir?  @relation(fields: [memoirId], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now())

  @@index([userId])
  @@map("galleries")
}

// ============ Friend ============
model Friend {
  id             String   @id @default(cuid())
  userId         String
  name           String
  avatar         String?
  addedAt        DateTime  @default(now())
  category       String   // 'family' | 'class_mate' | 'friend'
  relationship   String?  // 家族关系
  generation     Int?    // 辈分：+2,+3,+4=祖辈，+1=父辈，0=同辈，-1,-2,-3=子、孙辈
  parentId       String?  // 父节点ID，用于家族树
  spouseId       String?  // 配偶ID
  school         String?  // 学校
  classInfo      String?  // 班级信息
  graduationYear String?  // 毕业年份
  metAt          String?  // 认识地点
  metYear        String?  // 认识年份
  tags           String   // JSON array string，如工作单位、兴趣组等
  
  // Relations
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
  @@map("friends")
}
