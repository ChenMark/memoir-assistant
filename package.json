{
  "name": "memoir-assistant",
  "private": true,
  "version": "2.0.0",
  "engines": {
    "node": "24.x"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "cd server && npm run dev",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:server\"",
    "build": "tsc && vite build",
    "build:server": "cd server && npm run build",
    "preview": "vite preview",
    "postinstall": "cd server && npm install",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "eslint 'src/**/*.{ts,tsx}' 'server/src/**/*.ts'",
    "lint:fix": "eslint --fix 'src/**/*.{ts,tsx}' 'server/src/**/*.ts'",
    "format": "prettier --write 'src/**/*.{ts,tsx,css}' 'server/src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx,css}' 'server/src/**/*.ts'",
    "check": "npm run lint && npm run format:check"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "adm-zip": "^0.5.17",
    "ali-oss": "^6.21.0",
    "core-js": "^3.49.0",
    "crypto-js": "^4.2.0",
    "dotenv": "^17.4.2",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/ali-oss": "^6.23.3",
    "@types/archiver": "^8.0.0",
    "@types/crypto-js": "^4.2.2",
    "@types/dotenv": "^6.1.1",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.1",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@types/ua-parser-js": "^0.7.39",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^10.5.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "prettier": "^3.8.4",
    "ts-jest": "^29.4.11",
    "typescript": "^5.9.3",
    "vite": "^5.0.12"
  }
}
